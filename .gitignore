# Large data files — regenerate from the source Excel with scripts/build_import_csvs.py
import_files/*.csv

# Never commit secrets (DB connection string / password). The loader reads the
# connection string from an environment variable, so nothing secret is stored here.
.env
*.env

# Classified / sensitive content stays LOCAL ONLY — never pushed to GitHub.
# Fill in real serial-number mappings in a *.private.* copy (see the *.template.*
# version, which is safe to commit). Anything under docs/private/ is also ignored.
*.private.*
*.local.*
docs/private/

# Python cache
__pycache__/
*.pyc

# OS junk
.DS_Store
Thumbs.db
